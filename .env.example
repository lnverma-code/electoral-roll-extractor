# Copy this file to .env and fill in your key.
MISTRAL_API_KEY=your_mistral_api_key_here

# --- optional overrides (defaults shown) ---
OCR_PROVIDER=mistral
OCR_MODEL=mistral-ocr-latest
STRUCTURE_MODEL=mistral-small-latest

# --- authentication (REQUIRED - the app refuses to serve without these) ---
# Generate the hash with:  python make_password.py
# The hash is ':'-separated on purpose. Never use a '$' here: Docker Compose
# expands '$name' as a variable and would silently truncate the hash, making
# every login fail with "Invalid credentials".
APP_USERNAME=admin
APP_PASSWORD_HASH=pbkdf2_sha256:600000:<salt>:<hash>
